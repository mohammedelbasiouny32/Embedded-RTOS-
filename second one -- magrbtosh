/* ── Standard headers ───────────────────────────────────────────────────── */
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>

/* ── FreeRTOS headers ───────────────────────────────────────────────────── */
#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include "timers.h"
#include "semphr.h"

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 1 – CONFIGURATION (AUTOMATED FOR 4 CASES)
 * ═══════════════════════════════════════════════════════════════════════════ */
static const uint32_t p_drop_cases[4] = {10u, 20u, 40u, 80u};
static volatile uint8_t current_case_idx = 0;

#define P_DROP_PERMILLE   (p_drop_cases[current_case_idx])
#define TOUT_MS           200u      /* Retransmission timeout in ms         */

/* ── Fixed parameters (do NOT change) ──────────────────────────────────── */
#define L1                500u      /* Min packet length (bytes)             */
#define L2                1500u     /* Max packet length (bytes)             */
#define T1_MS             100u      /* Min inter-arrival time (ms)           */
#define T2_MS             200u      /* Max inter-arrival time (ms)           */
#define K_BYTES           40u       /* ACK packet size (bytes, fixed)        */
#define C_BITSEC          100000UL  /* Link capacity (bits/sec)              */
#define D_MS              5u        /* Propagation delay (ms)                */
#define P_ACK_PERMILLE    10u       /* ACK drop probability × 1000 = 0.01   */
#define MAX_RETRIES       4u        /* Max transmission attempts per packet  */
#define TARGET_PACKETS    2000u     /* Stop after this many unique receptions*/
#define HEADER_SIZE       8u        /* Packet header size in bytes           */

/* ── Stack sizes (in words = 4 bytes each on ARM Cortex-M4) ────────────── */
#define STACK_GEN         256u
#define STACK_SENDER      256u
#define STACK_DATALINK    256u
#define STACK_RECEIVER    256u
#define STACK_ACKLINK     256u
#define STACK_ACKHANDLER  256u
#define STACK_MONITOR     256u

/* ── Queue depths ───────────────────────────────────────────────────────── */
#define PKT_QUEUE_LEN     30u
#define LINK_QUEUE_LEN    30u
#define RECV_QUEUE_LEN    30u
#define ACKLINK_QUEUE_LEN 30u
#define ACK_QUEUE_LEN     30u

/* ── Task priorities ────────────────────────────────────────────────────── */
#define PRI_GENERATOR     ( tskIDLE_PRIORITY + 2u )
#define PRI_SENDER        ( tskIDLE_PRIORITY + 3u )
#define PRI_DATA_LINK     ( tskIDLE_PRIORITY + 2u )
#define PRI_RECEIVER      ( tskIDLE_PRIORITY + 2u )
#define PRI_ACK_LINK      ( tskIDLE_PRIORITY + 2u )
#define PRI_ACK_HANDLER   ( tskIDLE_PRIORITY + 3u )
#define PRI_MONITOR       ( tskIDLE_PRIORITY + 1u )

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 2 – DATA STRUCTURES
 * ═══════════════════════════════════════════════════════════════════════════ */
typedef struct __attribute__((packed)) {
    uint8_t  sender_id;
    uint8_t  dest_id;
    uint16_t length;
    uint32_t seq_num;
} PacketHeader_t;

typedef struct __attribute__((packed)) {
    PacketHeader_t header;
    uint8_t        payload[ L2 - HEADER_SIZE ];
} DataPacket_t;

typedef struct __attribute__((packed)) {
    uint8_t  ack_sender_id;
    uint8_t  ack_dest_id;
    uint32_t ack_seq_num;
    uint8_t  padding[ K_BYTES - 6u ];
} AckPacket_t;

/* Compile-time size assertions ─────────────────────────────────────────── */
typedef char _check_header [ (sizeof(PacketHeader_t) == 8u)       ? 1 : -1 ];
typedef char _check_ack    [ (sizeof(AckPacket_t)    == K_BYTES)  ? 1 : -1 ];

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 3 – GLOBAL HANDLES
 * ═══════════════════════════════════════════════════════════════════════════ */
static QueueHandle_t xPacketQueue  = NULL;
static QueueHandle_t xDataLinkQ    = NULL;
static QueueHandle_t xRecvQueue    = NULL;
static QueueHandle_t xAckLinkQ     = NULL;
static QueueHandle_t xAckQueue     = NULL;

static SemaphoreHandle_t xTxMutex     = NULL;
static SemaphoreHandle_t xStatsMutex  = NULL;
static SemaphoreHandle_t xSenderReady = NULL;
static TimerHandle_t xToutTimer = NULL;

static DataPacket_t * volatile pxTxPacket  = NULL;
static volatile uint8_t        ucRetryCnt  = 0u;

static volatile uint32_t ulGenerated       = 0UL;
static volatile uint32_t ulReceived        = 0UL;
static volatile uint32_t ulTotalTx         = 0UL;
static volatile uint32_t ulDroppedMaxRetry = 0UL;
static volatile uint32_t ulBytesHigh       = 0UL;
static volatile uint32_t ulBytesLow        = 0UL;

static volatile TickType_t xSimStartTick = 0u;
static volatile TickType_t xSimEndTick   = 0u;
static volatile BaseType_t xSimDone = pdFALSE;

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 4 – HELPER FUNCTIONS
 * ═══════════════════════════════════════════════════════════════════════════ */
static uint32_t ulRandInRange(uint32_t lo, uint32_t hi) {
    return lo + ( (uint32_t)rand() % (hi - lo + 1u) );
}

static BaseType_t xDropEvent(uint32_t permille) {
    uint32_t r = (uint32_t)rand() % 1000u;
    return (r < permille) ? pdTRUE : pdFALSE;
}

static TickType_t xCalcDelayTicks(uint32_t length_bytes) {
    uint32_t tx_ms   = (length_bytes * 8UL * 1000UL) / C_BITSEC;
    uint32_t total   = D_MS + tx_ms;
    return pdMS_TO_TICKS(total);
}

static void vAddBytes(uint32_t bytes) {
    uint32_t prev = ulBytesLow;
    ulBytesLow += bytes;
    if (ulBytesLow < prev) { ulBytesHigh++; }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 5 – TIMEOUT TIMER CALLBACK
 * ═══════════════════════════════════════════════════════════════════════════ */
static void vToutCallback(TimerHandle_t xTimer)
{
    (void)xTimer;
    if (xSimDone == pdTRUE) { return; } /* Safety check */

    xSemaphoreTake(xTxMutex, portMAX_DELAY);
    if (pxTxPacket == NULL) {
        xSemaphoreGive(xTxMutex);
        return;
    }

    ucRetryCnt++;
    if (ucRetryCnt < MAX_RETRIES) {
        DataPacket_t *net_copy = (DataPacket_t *) pvPortMalloc(sizeof(DataPacket_t));
        if (net_copy != NULL) {
            memcpy(net_copy, pxTxPacket, sizeof(DataPacket_t));
            xSemaphoreGive(xTxMutex);

            xSemaphoreTake(xStatsMutex, portMAX_DELAY);
            ulTotalTx++;
            xSemaphoreGive(xStatsMutex);

            if (xQueueSend(xDataLinkQ, &net_copy, 0) != pdTRUE) {
                vPortFree(net_copy);
                xSemaphoreTake(xTxMutex, portMAX_DELAY);
                vPortFree(pxTxPacket);
                pxTxPacket = NULL;
                ucRetryCnt = 0u;
                xSemaphoreGive(xTxMutex);
                xSemaphoreGive(xSenderReady);
                return;
            }
            xTimerReset(xToutTimer, 0);
        } else {
            xSemaphoreGive(xTxMutex);
        }
    } else {
        vPortFree(pxTxPacket);
        pxTxPacket = NULL;
        ucRetryCnt = 0u;
        xSemaphoreGive(xTxMutex);

        xSemaphoreTake(xStatsMutex, portMAX_DELAY);
        ulDroppedMaxRetry++;
        xSemaphoreGive(xStatsMutex);
        xSemaphoreGive(xSenderReady);
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 6 – TASK IMPLEMENTATIONS
 * ═══════════════════════════════════════════════════════════════════════════ */

static void PacketGeneratorTask(void *pvParameters)
{
    (void)pvParameters;
    uint32_t seq = 0UL;

    for (;;)
    {
        /* Pause generation while MonitorTask is resetting between cases */
        while (xSimDone == pdTRUE) {
            vTaskDelay(pdMS_TO_TICKS(50u));
        }

        vTaskDelay( pdMS_TO_TICKS( ulRandInRange(T1_MS, T2_MS) ) );

        /* Double check after delay */
        if (xSimDone == pdTRUE) { continue; }

        DataPacket_t *pkt = (DataPacket_t *) pvPortMalloc( sizeof(DataPacket_t) );
        if (pkt == NULL) { continue; }

        uint16_t L            = (uint16_t) ulRandInRange(L1, L2);
        pkt->header.sender_id = 1u;
        pkt->header.dest_id   = 2u;
        pkt->header.length    = L;
        pkt->header.seq_num   = seq;

        uint16_t paylen = (uint16_t)(L - HEADER_SIZE);
        memset(pkt->payload, 0xABu, paylen);

        if (xQueueSend(xPacketQueue, &pkt, pdMS_TO_TICKS(500u)) == pdTRUE) {
            seq++;
            xSemaphoreTake(xStatsMutex, portMAX_DELAY);
            ulGenerated++;
            xSemaphoreGive(xStatsMutex);
        } else {
            vPortFree(pkt);
        }
    }
}

static void SenderTask(void *pvParameters)
{
    (void)pvParameters;
    for (;;)
    {
        xSemaphoreTake(xSenderReady, portMAX_DELAY);

        DataPacket_t *pkt = NULL;
        if (xQueueReceive(xPacketQueue, &pkt, portMAX_DELAY) != pdTRUE) {
            xSemaphoreGive(xSenderReady);
            continue;
        }

        if (xSimDone == pdTRUE) {
            vPortFree(pkt);
            xSemaphoreGive(xSenderReady);
            continue;
        }

        xSemaphoreTake(xTxMutex, portMAX_DELAY);
        pxTxPacket = pkt;
        ucRetryCnt = 0u;
        xSemaphoreGive(xTxMutex);

        xSemaphoreTake(xStatsMutex, portMAX_DELAY);
        ulTotalTx++;
        xSemaphoreGive(xStatsMutex);

        DataPacket_t *net_copy = (DataPacket_t *) pvPortMalloc(sizeof(DataPacket_t));
        if (net_copy != NULL) {
            memcpy(net_copy, pkt, sizeof(DataPacket_t));
            xQueueSend(xDataLinkQ, &net_copy, portMAX_DELAY);
        }

        xTimerChangePeriod(xToutTimer, pdMS_TO_TICKS(TOUT_MS), 0u);
        xTimerStart(xToutTimer, 0u);
    }
}

static void DataLinkTask(void *pvParameters)
{
    (void)pvParameters;
    for (;;)
    {
        DataPacket_t *pkt = NULL;
        xQueueReceive(xDataLinkQ, &pkt, portMAX_DELAY);
        if (pkt == NULL) { continue; }

        vTaskDelay( xCalcDelayTicks((uint32_t)pkt->header.length) );

        /* Prevent 'Ghost Packets' from sneaking through during a case reset */
        if (xSimDone == pdTRUE) {
            vPortFree(pkt);
            continue;
        }

        if (xDropEvent(P_DROP_PERMILLE) == pdTRUE) {
            vPortFree(pkt);
        } else {
            if (xQueueSend(xRecvQueue, &pkt, pdMS_TO_TICKS(100u)) != pdTRUE) {
                vPortFree(pkt);
            }
        }
    }
}

static void ReceiverTask(void *pvParameters)
{
    (void)pvParameters;
    int32_t  last_seq = -1;

    for (;;)
    {
        DataPacket_t *pkt = NULL;
        xQueueReceive(xRecvQueue, &pkt, portMAX_DELAY);
        if (pkt == NULL) { continue; }

        if (xSimDone == pdTRUE) {
            vPortFree(pkt);
            continue;
        }

        uint32_t seq = pkt->header.seq_num;
        uint16_t len = pkt->header.length;

        AckPacket_t *ack = (AckPacket_t *) pvPortMalloc( sizeof(AckPacket_t) );
        if (ack != NULL) {
            memset(ack, 0, sizeof(AckPacket_t));
            ack->ack_sender_id = 2u;
            ack->ack_dest_id   = 1u;
            ack->ack_seq_num   = seq;
            if (xQueueSend(xAckLinkQ, &ack, pdMS_TO_TICKS(100u)) != pdTRUE) {
                vPortFree(ack);
            }
        }

        if ((int32_t)seq != last_seq) {
            last_seq = (int32_t)seq;

            xSemaphoreTake(xStatsMutex, portMAX_DELAY);
            if (ulReceived == 0UL) {
                xSimStartTick = xTaskGetTickCount();
            }
            ulReceived++;
            vAddBytes((uint32_t)len);

            if (ulReceived >= TARGET_PACKETS) {
                xSimEndTick = xTaskGetTickCount();
                xSimDone    = pdTRUE; /* Flags MonitorTask to print and reset */
            }
            xSemaphoreGive(xStatsMutex);
        }
        vPortFree(pkt);
    }
}

static void AckLinkTask(void *pvParameters)
{
    (void)pvParameters;
    for (;;)
    {
        AckPacket_t *ack = NULL;
        xQueueReceive(xAckLinkQ, &ack, portMAX_DELAY);
        if (ack == NULL) { continue; }

        vTaskDelay( xCalcDelayTicks((uint32_t)K_BYTES) );

        /* Prevent 'Ghost Packets' from sneaking through during a case reset */
        if (xSimDone == pdTRUE) {
            vPortFree(ack);
            continue;
        }

        if (xDropEvent(P_ACK_PERMILLE) == pdTRUE) {
            vPortFree(ack);
        } else {
            if (xQueueSend(xAckQueue, &ack, pdMS_TO_TICKS(100u)) != pdTRUE) {
                vPortFree(ack);
            }
        }
    }
}

static void AckHandlerTask(void *pvParameters)
{
    (void)pvParameters;
    for (;;)
    {
        AckPacket_t *ack = NULL;
        xQueueReceive(xAckQueue, &ack, portMAX_DELAY);
        if (ack == NULL) { continue; }

        if (xSimDone == pdTRUE) {
            vPortFree(ack);
            continue;
        }

        uint32_t ack_seq = ack->ack_seq_num;
        vPortFree(ack);

        xSemaphoreTake(xTxMutex, portMAX_DELAY);
        if ( (pxTxPacket != NULL) && (pxTxPacket->header.seq_num == ack_seq) ) {
            xTimerStop(xToutTimer, 0u);
            vPortFree(pxTxPacket);
            pxTxPacket = NULL;
            ucRetryCnt = 0u;
            xSemaphoreGive(xTxMutex);
            xSemaphoreGive(xSenderReady);
        } else {
            xSemaphoreGive(xTxMutex);
        }
    }
}

static void MonitorTask(void *pvParameters)
{
    (void)pvParameters;
    for (;;)
    {
        vTaskDelay( pdMS_TO_TICKS(500u) );

        if (xSimDone == pdTRUE)
        {
            /* 1. Wait for in-flight packets to finish or timeout naturally */
            vTaskDelay( pdMS_TO_TICKS(1000u) );

            /* 2. Compute and Print Stats for Current Case */
            TickType_t elapsed_ticks = xSimEndTick - xSimStartTick;
            uint32_t   elapsed_ms    = (uint32_t)(elapsed_ticks * (TickType_t)portTICK_PERIOD_MS);

            uint32_t throughput_bps = 0UL;
            if (elapsed_ms > 0UL) {
                throughput_bps = (uint32_t)( ((uint64_t)ulBytesLow * 1000ULL) / elapsed_ms );
            }

            uint32_t decided = ulReceived + ulDroppedMaxRetry;
            uint32_t avg_tx_x100 = 0UL;
            if (decided > 0UL) {
                avg_tx_x100 = (ulTotalTx * 100UL) / decided;
            }

            printf("\r\n====================================================\r\n");
            printf("  RESULTS FOR CASE %d/4\r\n", current_case_idx + 1);
            printf("====================================================\r\n");
            printf("  P_drop        = %lu permille (x0.001)\r\n", (unsigned long)P_DROP_PERMILLE);
            printf("  Tout          = %lu ms\r\n", (unsigned long)TOUT_MS);
            printf("----------------------------------------------------\r\n");
            printf("  Pkts generated        : %lu\r\n", (unsigned long)ulGenerated);
            printf("  Pkts received (unique): %lu\r\n", (unsigned long)ulReceived);
            printf("  Total bytes received  : %lu bytes\r\n", (unsigned long)ulBytesLow);
            printf("  Total transmissions   : %lu\r\n", (unsigned long)ulTotalTx);
            printf("  Pkts dropped (maxTx)  : %lu\r\n", (unsigned long)ulDroppedMaxRetry);
            printf("  Elapsed time          : %lu ms\r\n", (unsigned long)elapsed_ms);
            printf("----------------------------------------------------\r\n");
            printf("  Throughput            : %lu bytes/sec\r\n", (unsigned long)throughput_bps);
            printf("  Avg tx per packet     : %lu.%02lu\r\n", (unsigned long)(avg_tx_x100 / 100UL), (unsigned long)(avg_tx_x100 % 100UL));
            printf("====================================================\r\n");

            current_case_idx++;

            /* 3. Prepare next case or Halt */
            if (current_case_idx < 4)
            {
                printf("\r\n>>> Automatically preparing Case %d (P_drop = %lu)... \r\n", 
                       current_case_idx + 1, (unsigned long)p_drop_cases[current_case_idx]);

                /* Flush Queues safely to avoid memory leaks from lingering packets */
                DataPacket_t *dp;
                AckPacket_t *ap;
                while(xQueueReceive(xPacketQueue, &dp, 0) == pdTRUE) { vPortFree(dp); }
                while(xQueueReceive(xDataLinkQ,   &dp, 0) == pdTRUE) { vPortFree(dp); }
                while(xQueueReceive(xRecvQueue,   &dp, 0) == pdTRUE) { vPortFree(dp); }
                while(xQueueReceive(xAckLinkQ,    &ap, 0) == pdTRUE) { vPortFree(ap); }
                while(xQueueReceive(xAckQueue,    &ap, 0) == pdTRUE) { vPortFree(ap); }

                /* Reset TX buffer and stop timer */
                xSemaphoreTake(xTxMutex, portMAX_DELAY);
                if (pxTxPacket != NULL) { vPortFree(pxTxPacket); pxTxPacket = NULL; }
                ucRetryCnt = 0u;
                xTimerStop(xToutTimer, 0);
                xSemaphoreGive(xTxMutex);

                /* Ensure Sender has exactly 1 token to start */
                xSemaphoreTake(xSenderReady, 0); 
                xSemaphoreGive(xSenderReady);    

                /* Reset Statistics */
                xSemaphoreTake(xStatsMutex, portMAX_DELAY);
                ulGenerated       = 0UL;
                ulTotalTx         = 0UL;
                ulDroppedMaxRetry = 0UL;
                ulBytesHigh       = 0UL;
                ulBytesLow        = 0UL;
                ulReceived        = 0UL; /* Reset last so receiver triggers tick reset on next packet */
                xSemaphoreGive(xStatsMutex);

                /* Resume System */
                xSimDone = pdFALSE;
            }
            else
            {
                printf("\r\n✅ All 4 simulation cases completed successfully!\r\n");
                taskDISABLE_INTERRUPTS();
                for (;;);
            }
        }
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 7 – main()
 * ═══════════════════════════════════════════════════════════════════════════ */
int main(void)
{
    srand(12345u);

    xTxMutex    = xSemaphoreCreateMutex();
    xStatsMutex = xSemaphoreCreateMutex();
    configASSERT(xTxMutex    != NULL);
    configASSERT(xStatsMutex != NULL);

    xSenderReady = xSemaphoreCreateCounting(1u, 1u);
    configASSERT(xSenderReady != NULL);

    xPacketQueue = xQueueCreate(PKT_QUEUE_LEN,    sizeof(DataPacket_t *));
    xDataLinkQ   = xQueueCreate(LINK_QUEUE_LEN,   sizeof(DataPacket_t *));
    xRecvQueue   = xQueueCreate(RECV_QUEUE_LEN,   sizeof(DataPacket_t *));
    xAckLinkQ    = xQueueCreate(ACKLINK_QUEUE_LEN, sizeof(AckPacket_t *));
    xAckQueue    = xQueueCreate(ACK_QUEUE_LEN,    sizeof(AckPacket_t *));

    configASSERT(xPacketQueue != NULL);
    configASSERT(xDataLinkQ   != NULL);
    configASSERT(xRecvQueue   != NULL);
    configASSERT(xAckLinkQ    != NULL);
    configASSERT(xAckQueue    != NULL);

    xToutTimer = xTimerCreate("Tout", pdMS_TO_TICKS(TOUT_MS), pdFALSE, NULL, vToutCallback);
    configASSERT(xToutTimer != NULL);

    xTaskCreate(PacketGeneratorTask, "PktGen",   STACK_GEN,       NULL, PRI_GENERATOR,   NULL);
    xTaskCreate(SenderTask,          "Sender",   STACK_SENDER,    NULL, PRI_SENDER,      NULL);
    xTaskCreate(DataLinkTask,        "DataLink", STACK_DATALINK,  NULL, PRI_DATA_LINK,   NULL);
    xTaskCreate(ReceiverTask,        "Receiver", STACK_RECEIVER,  NULL, PRI_RECEIVER,    NULL);
    xTaskCreate(AckLinkTask,         "AckLink",  STACK_ACKLINK,   NULL, PRI_ACK_LINK,    NULL);
    xTaskCreate(AckHandlerTask,      "AckHdlr",  STACK_ACKHANDLER,NULL, PRI_ACK_HANDLER, NULL);
    xTaskCreate(MonitorTask,         "Monitor",  STACK_MONITOR,   NULL, PRI_MONITOR,     NULL);

    printf("\r\n====================================================\r\n");
    printf("Starting AUTOMATED simulation for 4 P_DROP cases\r\n");
    printf("Target = %lu pkts per case\r\n", (unsigned long)TARGET_PACKETS);
    printf("====================================================\r\n");

    vTaskStartScheduler();

    for (;;);
    return 0;
}

/* ═══════════════════════════════════════════════════════════════════════════
 * SECTION 8 – FreeRTOS Hook Functions
 * ═══════════════════════════════════════════════════════════════════════════ */
void vApplicationMallocFailedHook(void) {
    taskDISABLE_INTERRUPTS();
    printf("FATAL: pvPortMalloc failed\r\n");
    for (;;);
}

void vApplicationStackOverflowHook(TaskHandle_t xTask, char *pcTaskName) {
    (void)xTask;
    taskDISABLE_INTERRUPTS();
    printf("FATAL: Stack overflow in [%s]\r\n", pcTaskName);
    for (;;);
}

void vApplicationIdleHook(void) {}
void vApplicationTickHook(void) {}
